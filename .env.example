PORT=8091

# Set all three to enable auto-connect (skips login form)
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
SSH_PASSWORD=

# Optional: env vars to pass to the remote shell (requires matching AcceptEnv in sshd_config)
# Comma-separated KEY=VALUE pairs, e.g. SSH_ENV=ENVIRONMENT=WNG-11124,FOO=bar
SSH_ENV=
